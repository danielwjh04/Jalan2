{
  "functions": [
    {
      "source": "server",
      "codebase": "default",
      "runtime": "nodejs22",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "test",
        "scripts",
        "data",
        "fixtures/**/*.mp4",
        "fixtures/**/*.m4a",
        "fixtures/**/*.wav",
        "fixtures/**/image_*.jpg"
      ]
    }
  ]
}
