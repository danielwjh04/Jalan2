# Server
PORT=3001

# Pipeline: live = always call services, cached = serve booking.cached.json only,
# auto = live with cached fallback on any stage error (default)
PIPELINE_MODE=auto

# Adapters
EXTRACTOR=fixture            # fixture | tikhub | xhs-downloader | auto (xhs via sidecar, tiktok via TikHub)
XHS_DOWNLOADER_URL=http://127.0.0.1:5556
STT_PROVIDER=openai          # openai | elevenlabs
MESSAGING_PROVIDER=mock      # mock | twilio | telegram

# OpenAI (the only key required for the live pipeline)
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_FUSION_MODEL=gpt-4o-2024-08-06

# ElevenLabs voice layer (Scribe STT + TTS). TTS_PROVIDER=cached serves only
# committed fixture mp3s; elevenlabs synthesizes live and fills the runtime
# cache. Voice id defaults to a stock premade voice; override from the
# dashboard if you prefer another.
ELEVENLABS_API_KEY=
TTS_PROVIDER=cached          # cached | elevenlabs
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v1

# Exa web retrieval (dish images + operator trust search). fixture serves
# results captured into fixtures/retrieval/results.json; exa searches live.
EXA_API_KEY=
RETRIEVAL_PROVIDER=fixture   # fixture | exa
OPENAI_MENU_MODEL=gpt-4o-mini

# Route planning. Keep the key server-side; enable Places API (New) and Routes API.
ROUTING_PROVIDER=auto        # auto | offline | google
PLACES_PROVIDER=auto         # auto | offline | google
GOOGLE_MAPS_API_KEY=

# TikHub video extractor (optional hosted fallback)
TIKHUB_TOKEN=

# Twilio WhatsApp sandbox (primary messaging provider)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The demo operator phone. Outbound messages only ever go here, never to
# numbers extracted from videos.
OPERATOR_WHATSAPP=

# Telegram bot (fallback messaging provider)
TELEGRAM_BOT_TOKEN=
OPERATOR_TELEGRAM_CHAT_ID=

# Mock messaging: auto-reply YES after N ms (0 = never)
MOCK_AUTO_CONFIRM_MS=0
