{
  "expo": {
    "name": "Jalan2",
    "slug": "jalan2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-bobo-malaysia.png",
    "scheme": "jalan2",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jalan2.app",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Jalan2 connects to the development server on your Mac while testing the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10A6E8",
        "foregroundImage": "./assets/images/icon-bobo-malaysia.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2A2C2F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Jalan2 uses the camera so you can snap a kopitiam menu board to scan.",
          "photosPermission": "Jalan2 uses your photo library so you can pick a menu photo to scan."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
